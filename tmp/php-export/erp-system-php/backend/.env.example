# ============================================================
# Настройки подключения к базе данных MySQL
# Скопируйте этот файл в .env и впишите свои значения
# (install.sh делает это автоматически)
# ============================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=erp_system
DB_USER=erp_user
DB_PASSWORD=CHANGE_ME_PASSWORD
