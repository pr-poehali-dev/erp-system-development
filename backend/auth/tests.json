{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "nouser", "password": "wrongpass"},
      "expectedStatus": 401
    },
    {
      "name": "Login without body fields",
      "method": "POST",
      "path": "/?action=login",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "Unknown action",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 404
    }
  ]
}
